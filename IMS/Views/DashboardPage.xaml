<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:IMS.ViewModels"
             xmlns:models="clr-namespace:IMS.Models"
             x:Class="IMS.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Dashboard">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="24">

            <!-- ─── Welcome Header ─── -->
            <VerticalStackLayout Spacing="4" Margin="0,0,0,4">
                <Label Text="{Binding WelcomeMessage}" Style="{StaticResource HeadlineMedium}" />
                <Label Text="{Binding UserRole}" Style="{StaticResource BodyMedium}"
                       TextColor="{StaticResource OnSurfaceVariant}" />
            </VerticalStackLayout>

            <!-- ─── KPI Cards Row 1 ─── -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                <Frame Grid.Column="0" Style="{StaticResource ElevatedCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding TotalAssets}" Style="{StaticResource HeadlineLarge}"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Total Assets" Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" Style="{StaticResource ElevatedCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding AvailableAssets}" Style="{StaticResource HeadlineLarge}"
                               TextColor="{StaticResource StatusAvailable}" />
                        <Label Text="Available" Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="2" Style="{StaticResource ElevatedCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding InUseAssets}" Style="{StaticResource HeadlineLarge}"
                               TextColor="{StaticResource StatusInUse}" />
                        <Label Text="In Use" Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="3" Style="{StaticResource ElevatedCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding InRepairAssets}" Style="{StaticResource HeadlineLarge}"
                               TextColor="{StaticResource StatusInRepair}" />
                        <Label Text="In Repair" Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- ─── KPI Cards Row 2 ─── -->
            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="12">
                <Frame Grid.Column="0" Style="{StaticResource ElevatedCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding ActiveLeases}" Style="{StaticResource HeadlineLarge}"
                               TextColor="{StaticResource Tertiary}" />
                        <Label Text="Active Leases" Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" Style="{StaticResource ElevatedCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding OpenSmrTickets}" Style="{StaticResource HeadlineLarge}"
                               TextColor="{StaticResource Error}" />
                        <Label Text="Open SMR Tickets" Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="2" Style="{StaticResource ElevatedCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding ActiveProjects}" Style="{StaticResource HeadlineLarge}"
                               TextColor="{StaticResource Primary}" />
                        <Label Text="Active Projects" Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="3" Style="{StaticResource ElevatedCard}">
                    <VerticalStackLayout Spacing="6">
                        <Label Text="{Binding LowStockItems}" Style="{StaticResource HeadlineLarge}"
                               TextColor="{StaticResource Warning}" />
                        <Label Text="Low Stock Alerts" Style="{StaticResource LabelMedium}"
                               TextColor="{StaticResource OnSurfaceVariant}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- ─── Activity Sections ─── -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="16" Margin="0,4,0,0">
                <!-- Recent Leases -->
                <Frame Grid.Column="0" Style="{StaticResource FilledCard}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Recent Lease Activity" Style="{StaticResource TitleMedium}" />
                        <CollectionView ItemsSource="{Binding RecentLeases}" HeightRequest="220">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:LeaseTransactionLedger">
                                    <Frame Style="{StaticResource CompactCard}" Margin="0,3" Padding="12,8">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                            <BoxView Grid.Column="0" WidthRequest="3" CornerRadius="2"
                                                     Color="{StaticResource Primary}" VerticalOptions="Fill" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="{Binding OutboundTimestamp, StringFormat='Dispatched: {0:MMM dd, yyyy}'}"
                                                       Style="{StaticResource BodySmall}" />
                                                <Label Text="{Binding ReturnCondition, TargetNullValue='Active'}"
                                                       Style="{StaticResource LabelSmall}"
                                                       TextColor="{StaticResource OnSurfaceVariant}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="{Binding OutboundTimestamp, StringFormat='{0:MMM dd}'}"
                                                   Style="{StaticResource LabelSmall}"
                                                   TextColor="{StaticResource OnSurfaceVariant}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="No recent lease activity"
                                       Style="{StaticResource BodySmall}"
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       HorizontalOptions="Center" Margin="0,20" />
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>

                <!-- Open SMR Tickets -->
                <Frame Grid.Column="1" Style="{StaticResource FilledCard}">
                    <VerticalStackLayout Spacing="12">
                        <Label Text="Open SMR Tickets" Style="{StaticResource TitleMedium}" />
                        <CollectionView ItemsSource="{Binding RecentTickets}" HeightRequest="220">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:SmrServiceTicket">
                                    <Frame Style="{StaticResource CompactCard}" Margin="0,3" Padding="12,8">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                                            <BoxView Grid.Column="0" WidthRequest="3" CornerRadius="2"
                                                     Color="{StaticResource Warning}" VerticalOptions="Fill" />
                                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                                <Label Text="{Binding Description}"
                                                       Style="{StaticResource BodySmall}"
                                                       LineBreakMode="TailTruncation" MaxLines="1" />
                                                <Label Text="{Binding TicketStatus}"
                                                       Style="{StaticResource LabelSmall}"
                                                       TextColor="{StaticResource OnSurfaceVariant}" />
                                            </VerticalStackLayout>
                                            <Label Grid.Column="2" Text="{Binding CreatedAt, StringFormat='{0:MMM dd}'}"
                                                   Style="{StaticResource LabelSmall}"
                                                   TextColor="{StaticResource OnSurfaceVariant}"
                                                   VerticalOptions="Center" />
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                            <CollectionView.EmptyView>
                                <Label Text="No open tickets"
                                       Style="{StaticResource BodySmall}"
                                       TextColor="{StaticResource OnSurfaceVariant}"
                                       HorizontalOptions="Center" Margin="0,20" />
                            </CollectionView.EmptyView>
                        </CollectionView>
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <!-- ─── Recent Activity Log ─── -->
            <Frame Style="{StaticResource OutlinedCard}" Margin="0,4,0,0">
                <VerticalStackLayout Spacing="12">
                    <Label Text="Recent Activity Log" Style="{StaticResource TitleMedium}" />
                    <CollectionView ItemsSource="{Binding RecentActivity}" HeightRequest="260">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:AuditLogEntry">
                                <Frame Style="{StaticResource CompactCard}" Margin="0,2" Padding="12,8">
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                        <Frame Grid.Column="0" Padding="8,4" CornerRadius="6"
                                               BackgroundColor="{StaticResource PrimaryContainer}"
                                               HasShadow="False" BorderColor="Transparent">
                                            <Label Text="{Binding Action}" Style="{StaticResource LabelSmall}"
                                                   TextColor="{StaticResource OnPrimaryContainer}" />
                                        </Frame>
                                        <Label Grid.Column="1" Text="{Binding Details}"
                                               Style="{StaticResource BodySmall}"
                                               LineBreakMode="TailTruncation" MaxLines="1"
                                               VerticalOptions="Center" />
                                        <Label Grid.Column="2" Text="{Binding Timestamp, StringFormat='{0:MMM dd HH:mm}'}"
                                               Style="{StaticResource LabelSmall}"
                                               TextColor="{StaticResource OnSurfaceVariant}"
                                               VerticalOptions="Center" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
